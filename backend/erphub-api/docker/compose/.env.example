# =============================================================
# .env.example — Variables de entorno para erphub-api
# =============================================================
# INSTRUCCIONES:
#   DEV:  Copiar a .env en esta misma carpeta y completar los valores.
#         El archivo .env está en .gitignore — nunca comitear valores reales.
#   PROD: NO usar este archivo. Exportar las variables directamente
#         en el sistema del servidor:  export VAR=valor
#         Luego ejecutar: docker compose -f docker-compose.prod.yml up -d
# =============================================================

# -------------------------------------------------------------
# SPRING — Perfil activo
# -------------------------------------------------------------
SPRING_PROFILES_ACTIVE=dev
# PROD: cambiar a "prod"

SPRING_CONFIG_IMPORT=optional:configserver:http://localhost:8088
# PROD: configserver:http://config-server:8088  (sin "optional:")

LOG_LEVEL_SPRING=INFO
# PROD: WARN

# -------------------------------------------------------------
# PostgreSQL
# -------------------------------------------------------------
POSTGRES_USER=admin
POSTGRES_PASSWORD=root1234

# Puerto expuesto al host (solo DEV — en PROD postgres no expone puerto)
POSTGRES_HOST_PORT=5544
POSTGRES_CONTAINER_PORT=5432

# Hostname que usan los microservicios
POSTGRES_LOCAL_HOST=localhost
# En Docker (DEV + PROD): usar el nombre del servicio Docker
POSTGRES_NETWORK_HOST=postgres

# -------------------------------------------------------------
# RabbitMQ
# -------------------------------------------------------------
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# Hostname que usan los microservicios
RABBITMQ_LOCAL_HOST=localhost
# En Docker (DEV + PROD): usar el nombre del servicio Docker
RABBITMQ_NETWORK_HOST=rabbitmq

# -------------------------------------------------------------
# API Gateway
# -------------------------------------------------------------
# Orígenes permitidos por CORS (separados por coma si son varios)
# DEV: http://localhost:4200 (hardcoded en api-gateway.yml)
# PROD: dominio real, ej: https://app.midominio.com
CORS_ALLOWED_ORIGINS=https://example.com

# -------------------------------------------------------------
# Bases de datos por microservicio
# (Los defaults ya están definidos en los configs del config-server,
#  solo es necesario setear estas variables si querés nombres distintos)
# -------------------------------------------------------------
BRANCH_DB=branch_db
BRAND_DB=brand_db
CASH_DB=cash_db
CATEGORY_DB=category_db
CUSTOMER_DB=customer_db
EXCHANGE_DB=exchange_db
IDENTITY_DB=identity_db
IMAGE_DB=image_db
INVENTORY_DB=inventory_db
LOCATION_DB=location_db
PRICING_DB=pricing_db
PRODUCT_DB=product_db
PURCHASE_DB=purchase_db
REPORTING_DB=reporting_db
SALES_DB=sales_db
SUPPLIER_CATALOG_DB=supplier_catalog_db
SUPPLIER_DB=supplier_db
TENANT_DB=tenant_db

# -------------------------------------------------------------
# identity-sv — Seguridad (solo necesario cuando se active)
# -------------------------------------------------------------
BASE64_SECRET_KEY=
JWT_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# Mail (opcional)
MAIL_ENABLED=false
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# Brevo API (alternativa a SMTP)
BREVO_API_KEY=
BREVO_API_URL=https://api.brevo.com/v3

# URLs de frontend para emails
RESET_PASSWORD_BASE_URL=http://localhost:5173/reset-password
ACCEPT_INVITE_BASE_URL=http://localhost:5173/accept-invite

# CORS para identity-sv
CORS_ALLOWED_ORIGINS_IDENTITY=http://localhost:3000,http://localhost:4200,http://localhost:5173

# -------------------------------------------------------------
# supplier-catalog-sv — Límites de carga
# -------------------------------------------------------------
SUPPLIER_CATALOG_MAX_FILE_SIZE=20MB
SUPPLIER_CATALOG_MAX_REQUEST_SIZE=25MB
SUPPLIER_CATALOG_MAX_SWALLOW_SIZE=26MB
